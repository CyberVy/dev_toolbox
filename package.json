{
  "name": "dev_toolbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tauri": "cargo tauri",
    "dev": "npm run dev:sw & next dev -p 4000",
    "build": "npm run build:sw & next build",
    "start": "npx serve out -p 4000",
    "lint": "eslint src",
    "dev:sw": "esbuild src/sw/main.worker.ts --bundle --format=esm --target=esnext --outfile=public/sw.js --watch=forever",
    "build:sw": "esbuild src/sw/main.worker.ts --bundle --format=esm --target=esnext --outfile=public/sw.js --minify",
    "dev:main_window_injection": "esbuild src-tauri/src/inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/src/inject.js --watch=forever --banner:js=\"// Generated by src-tauri/src/inject.ts\"",
    "build:main_window_injection": "esbuild src-tauri/src/inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/src/inject.js --banner:js=\"// Generated by src-tauri/src/inject.ts\"",
    "dev:ios_external_window_injection": "esbuild src-tauri/gen/apple/assets/webview_external_inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/gen/apple/assets/webview_external_inject.js --watch=forever --banner:js=\"// Generated by src-tauri/gen/apple/assets/webview_external_inject.ts\"",
    "build:ios_external_window_injection": "esbuild src-tauri/gen/apple/assets/webview_external_inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/gen/apple/assets/webview_external_inject.js --banner:js=\"// Generated by src-tauri/gen/apple/assets/webview_external_inject.ts\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "next": "16.1.5",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.27.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.8",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
